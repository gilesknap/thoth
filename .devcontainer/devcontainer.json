// For format details, see https://containers.dev/implementors/json_reference/
//
// Scheme: the project venv is a plain uv-default `.venv` in the workspace, and the
// workspace + shared cache are bind-mounted at IDENTICAL paths inside and outside
// the container. One venv (with the absolute paths uv writes into it) is therefore
// valid from both sides — host editors/language servers (e.g. Zed) and in-container
// tooling use the same interpreter and site-packages.
{
    "name": "Python 3 Developer Container",
    "build": {
        "dockerfile": "../Dockerfile",
        "target": "developer"
    },
    // containerEnv is baked in at container creation, so it applies to EVERY exec
    // path — including editors that bypass remoteEnv (Zed execs into the container
    // directly). The cache lives under the host $HOME and is mounted at the same
    // path in the container (see mounts), so uv-managed interpreters installed
    // there resolve from both sides.
    "containerEnv": {
        "PRE_COMMIT_HOME": "${localEnv:HOME}/.cache/devcontainer-shared/pre-commit",
        "UV_CACHE_DIR": "${localEnv:HOME}/.cache/devcontainer-shared/uv",
        "UV_PYTHON_CACHE_DIR": "${localEnv:HOME}/.cache/devcontainer-shared/uv-python",
        "UV_PYTHON_INSTALL_DIR": "${localEnv:HOME}/.cache/devcontainer-shared/uv-python-installs"
    },
    "remoteEnv": {
        // Allow X11 apps to run inside the container (interactive VSCode only;
        // absence elsewhere is harmless)
        "DISPLAY": "${localEnv:DISPLAY}"
    },
    "customizations": {
        "vscode": {
            // Set *default* container specific settings.json values on container create.
            "settings": {
                // The project venv is the uv default: .venv in the workspace
                "python.defaultInterpreterPath": "${containerWorkspaceFolder}/.venv/bin/python",
                // Workaround to prevent garbled python REPL in the terminal
                // https://github.com/microsoft/vscode-python/issues/25505
                "python.terminal.shellIntegration.enabled": false
            },
            // Add the IDs of extensions you want installed when the container is created.
            "extensions": [
                "ms-python.python",
                "github.vscode-github-actions",
                "tamasfe.even-better-toml",
                "redhat.vscode-yaml",
                "ryanluker.vscode-coverage-gutters",
                "charliermarsh.ruff",
                "ms-azuretools.vscode-docker"
            ]
        }
    },
    // Create the config folder for the bash-config feature and the shared cache
    "initializeCommand": "mkdir -p ${localEnv:HOME}/.config/terminal-config ${localEnv:HOME}/.cache/devcontainer-shared",
    "runArgs": [
        // Allow the container to access the host X11 display and EPICS CA
        "--net=host",
        // Make sure SELinux does not disable with access to host filesystems like tmp
        "--security-opt=label=disable"
    ],
    "mounts": [
        // Mount in the user terminal config folder so it can be edited
        {
            "source": "${localEnv:HOME}/.config/terminal-config",
            "target": "/user-terminal-config",
            "type": "bind"
        },
        // Persistent cross-container cache for uv, pre-commit, and uv-managed
        // pythons, mounted at the SAME path on both sides so the interpreter
        // symlinks inside .venv resolve on the host too
        {
            "source": "${localEnv:HOME}/.cache/devcontainer-shared",
            "target": "${localEnv:HOME}/.cache/devcontainer-shared",
            "type": "bind"
        }
    ],
    // Mount the parent directory at its own host path: container paths mirror host
    // paths (so .venv works from both sides) and sibling checkouts remain available
    // for editable peer installs
    "workspaceMount": "source=${localWorkspaceFolder}/..,target=${localWorkspaceFolder}/..,type=bind",
    "workspaceFolder": "${localWorkspaceFolder}",
    // After the container is created, recreate the venv then make pre-commit first run faster.
    // Clear core.hooksPath first: if it's set (even to git's default hooks dir) pre-commit
    // "cowardly refuses" to install. The bind-mounted .git/config can carry a stale value in
    // from a past tool, so unset it on every rebuild to keep this step self-healing.
    // pre-commit lives in the workspace .venv and is not on the base image PATH,
    // so invoke it through `uv run`.
    // --extra runtime: the runtime libs (anthropic, slack-bolt, ...) are an optional
    // extra, but src/ imports them directly — without the extra in the venv the
    // language server cannot resolve those imports.
    "postCreateCommand": "uv venv --clear && uv sync --extra runtime && (git config --unset-all core.hooksPath 2>/dev/null || true) && uv run pre-commit install --install-hooks"
}

filters:
  and:
    - file.inFolder("entities")
    - file.ext == "md"
properties:
  aliases:  { displayName: Aliases }
  tags:     { displayName: Tags }
  source:   { displayName: Source }
views:
  - type: table
    name: All Entities
    order: [file.name, aliases, tags, source, updated]
    sort: [{ property: file.name, direction: ASC }]

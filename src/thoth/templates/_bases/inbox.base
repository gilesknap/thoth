filters:
  and:
    - file.inFolder("inbox")
    - file.ext == "md"
properties:
  title:   { displayName: Title }
  created: { displayName: Captured }
  tags:    { displayName: Tags }
  source:  { displayName: Via }
views:
  - type: table
    name: Needs Filing
    filters:
      not:
        - file.name == "README"
    order: [file.name, created, source, tags]
    sort: [{ property: created, direction: DESC }]

#!/usr/bin/env bash
# thoth/bin/vault-commit — stage explicit paths, then commit + rebase + push.
#
# Usage: vault-commit <message> [-- <path>...]
#
# When one or more vault-relative paths follow a literal ``--`` they are the EXACT
# set staged for this commit (``git add -- <path>...``); with no paths the script
# commits whatever is already staged in the index (the batch path stages each
# capture incrementally up front). It never uses ``git add -A`` (issue #85): a
# blanket stage of the whole working tree let one capture's commit sweep a
# *different*, concurrent capture's just-written but-untracked asset into the wrong
# commit (the Slack daemon runs each capture on a worker thread sharing one working
# tree), so a page could be committed without its embedded ``![[asset]]``. Staging
# only this capture's own paths makes each commit atomic over its own page(s) + raw
# + assets + log.md and never touches another in-flight capture's untracked files. A
# path that names a deleted file (e.g. a superseded inbox/ hold) stages the deletion,
# exactly as ``git add -- <path>`` does.
#
# Carried forward from the SPEC (Appendix -> Git wrappers & .gitignore).
# Commit FIRST so the working tree is clean, THEN rebase onto any Obsidian pushes
# that landed during the batch. Committing before the rebase means no autostash is
# needed, so a conflicting Obsidian push surfaces as a clean rebase conflict (fail
# loudly) instead of a half-applied mid-stash-pop state. The agent never
# force-pushes. Auth is gh's credential helper over HTTPS (never SSH, never a
# PAT-in-URL);
# GIT_CONFIG_GLOBAL=/dev/null neutralises any global insteadOf ssh-rewrite.
#
# Push target: the vault's OWN remote (THOTH_GIT_REMOTE, default "origin") — NOT a
# hardcoded owner URL. The clone already knows where it came from, so we push back to
# the same place the rebase pulled from; nothing is owner-specific. THOTH_PUSH_REMOTE
# may override the target (a URL, path, or remote name) for tests/CI; when it is unset
# and "origin" is not configured the script FAILS LOUDLY rather than guessing, so it can
# never silently target someone else's repo. THOTH_GIT_REMOTE / THOTH_GIT_BRANCH default
# to "origin" / "main", so a test can redirect both the rebase and the push at a LOCAL
# bare repo in tmp_path. The credential-helper line is a documented no-op for a
# local-path remote.
set -euo pipefail
VAULT="${PKM_VAULT:-/opt/pkm-vault}"
MSG="${1:-ingest $(date -u +%Y-%m-%dT%H:%MZ)}"
shift || true
# Everything after the message (the caller passes a literal ``--`` then the explicit
# vault-relative paths) is the exact set to stage. With no paths we commit the index
# as-is (the batch path stages incrementally). Drop the leading ``--`` if present.
if [ "${1:-}" = "--" ]; then shift; fi
PATHS=("$@")
REMOTE="${THOTH_GIT_REMOTE:-origin}"
BRANCH="${THOTH_GIT_BRANCH:-main}"
# Default the push target to the vault's own remote (origin), not a hardcoded owner.
PUSH_REMOTE="${THOTH_PUSH_REMOTE:-$REMOTE}"
# Vault auth. When GITHUB_PKM_VAULT_TOKEN is set (systemd EnvironmentFile / cron env),
# feed it to git as an x-access-token HTTPS credential via an inline credential helper —
# the token stays in the process env ONLY (never in the URL, git config, or reflog). When
# it is unset, fall back to gh's credential helper (HTTPS, never SSH), preserving the
# prior behaviour for dev/test runs and local-path remotes (a documented no-op there).
if [ -n "${GITHUB_PKM_VAULT_TOKEN:-}" ]; then
    export GITHUB_PKM_VAULT_TOKEN
    CRED_HELPER='!f() { echo username=x-access-token; echo "password=${GITHUB_PKM_VAULT_TOKEN}"; }; f'
else
    CRED_HELPER='!gh auth git-credential'
fi
cd "$VAULT"
# When falling back to the named remote, it must actually be configured; otherwise the
# clone has no usable origin and we refuse to push rather than target an unknown repo.
if [ -z "${THOTH_PUSH_REMOTE:-}" ] && ! git remote get-url "$PUSH_REMOTE" >/dev/null 2>&1
then
    echo "VAULT PUSH ERROR: no '$PUSH_REMOTE' remote configured and THOTH_PUSH_REMOTE \
unset; refusing to push (set a remote or THOTH_PUSH_REMOTE)." >&2
    exit 1
fi
# Stage only this capture's own paths (never ``add -A`` — see the header). A path may
# name a created/updated file OR a deletion (a superseded inbox/ hold). Keep only paths
# that exist in the working tree (a create/update) or are already tracked (so a deletion
# stages): a never-tracked, now-deleted hold (created AND removed within one uncommitted
# run) is in neither and is dropped, since ``git add -- <missing>`` would otherwise fail
# the whole commit on an unmatched pathspec. With no paths, commit the staged index.
if [ "${#PATHS[@]}" -gt 0 ]; then
    STAGE=()
    for p in "${PATHS[@]}"; do
        if [ -e "$p" ] || git ls-files --error-unmatch -- "$p" >/dev/null 2>&1; then
            STAGE+=("$p")
        fi
    done
    if [ "${#STAGE[@]}" -gt 0 ]; then
        git add -- "${STAGE[@]}"
    fi
fi
git diff --cached --quiet && { echo "nothing to commit"; exit 0; }
git commit -m "agent: $MSG"
if ! GIT_CONFIG_GLOBAL=/dev/null git -c credential.helper="$CRED_HELPER" \
        pull --rebase "$REMOTE" "$BRANCH"; then
    echo "VAULT CONFLICT during rebase — resolve in Obsidian; not pushing." >&2
    GIT_CONFIG_GLOBAL=/dev/null git rebase --abort || true
    exit 1   # wrapper surfaces the conflicting path over Slack; never clobber
fi
GIT_CONFIG_GLOBAL=/dev/null git -c credential.helper="$CRED_HELPER" \
    push "$PUSH_REMOTE" "$BRANCH"

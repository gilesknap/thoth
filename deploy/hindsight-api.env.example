# hindsight-api server config — read by deploy/thoth-hindsight.service (EnvironmentFile),
# NOT by thoth. Install at <THOTH_HOME>/hindsight-api.env (chmod 600). Kept separate from
# thoth's own .env so the index server never sees thoth's Slack/MCP secrets.
#
# Fact-extraction runs on Anthropic Claude (the same vendor thoth uses); embeddings run
# LOCALLY on the box (no external embedding calls); Postgres is hindsight-api's own
# embedded instance addressed by the `pg0://` scheme (no separate DB service to run).

# LLM provider for fact-extraction + consolidation. `claude-haiku-4-5` is cheap and ample
# for extraction. Reuse thoth's ANTHROPIC_API_KEY value here.
HINDSIGHT_API_LLM_PROVIDER=anthropic
HINDSIGHT_API_LLM_MODEL=claude-haiku-4-5
HINDSIGHT_API_LLM_API_KEY=sk-ant-...

# Local, on-CPU embeddings (default). No external embedding quota to exhaust.
HINDSIGHT_API_EMBEDDINGS_PROVIDER=local

# Embedded Postgres managed by hindsight-api itself (data under ~/.pg0). The instance name
# is the `pg0://` authority; keep it stable so the same data dir is reused across restarts.
HINDSIGHT_API_DATABASE_URL=pg0://hindsight-embed-thoth

HINDSIGHT_API_LOG_LEVEL=info
